generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id        String   @id
  name      String
  isActive  Boolean  @default(true)
  config    Json?
  createdAt DateTime @default(now())

  gameResults       GameResult[]
  seasons           Season[]
  leaderboardGlobal LeaderboardGlobal[]
  leaderboardWeekly LeaderboardWeekly[]

  @@map("games")
}

model GuestPlayer {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  gameResults       GameResult[]
  leaderboardGlobal LeaderboardGlobal[]
  leaderboardWeekly LeaderboardWeekly[]

  @@map("guest_players")
}

model GameResult {
  id         String   @id @default(uuid())
  gameId     String
  guestId    String
  score      Int
  duration   Int
  replayHash String
  metadata   Json?
  createdAt  DateTime @default(now())

  game  Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  guest GuestPlayer @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([gameId, replayHash])
  @@index([gameId, guestId])
  @@index([gameId, score(sort: Desc)])
  @@map("game_results")
}

model Season {
  id      String    @id @default(uuid())
  gameId  String
  startAt DateTime  @default(now())
  endAt   DateTime?

  game              Game                @relation(fields: [gameId], references: [id], onDelete: Cascade)
  leaderboardWeekly LeaderboardWeekly[]

  @@index([gameId, startAt])
  @@index([gameId, endAt])
  @@map("seasons")
}

model LeaderboardGlobal {
  gameId    String
  guestId   String
  bestScore Int
  updatedAt DateTime @updatedAt

  game  Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  guest GuestPlayer @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@id([gameId, guestId])
  @@index([gameId, bestScore(sort: Desc)])
  @@map("leaderboard_global")
}

model LeaderboardWeekly {
  gameId    String
  seasonId  String
  guestId   String
  bestScore Int
  updatedAt DateTime @updatedAt

  game   Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  guest  GuestPlayer @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@id([gameId, seasonId, guestId])
  @@index([gameId, seasonId, bestScore(sort: Desc)])
  @@map("leaderboard_weekly")
}

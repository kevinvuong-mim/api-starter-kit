generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id        String   @id
  name      String
  isActive  Boolean  @default(true)
  config    Json?
  createdAt DateTime @default(now())

  gameResults GameResult[]
  leaderboard Leaderboard[]

  @@map("games")
}

model GuestPlayer {
  id        String   @id @default(uuid())
  name      String?
  createdAt DateTime @default(now())

  gameResults GameResult[]
  leaderboard Leaderboard[]

  @@map("guest_players")
}

model GameResult {
  id         String   @id @default(uuid())
  gameId     String
  guestId    String
  score      Int
  duration   Int
  replayHash String
  metadata   Json?
  createdAt  DateTime @default(now())

  game  Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  guest GuestPlayer @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([gameId, replayHash])
  @@index([gameId, guestId])
  @@index([gameId, score(sort: Desc)])
  @@map("game_results")
}

model Leaderboard {
  gameId    String
  guestId   String
  bestScore Int
  updatedAt DateTime @updatedAt

  game  Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  guest GuestPlayer @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@id([gameId, guestId])
  @@index([gameId, bestScore(sort: Desc)])
  @@map("leaderboard")
}
